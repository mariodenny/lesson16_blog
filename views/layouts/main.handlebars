<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Blog</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background: #1a1a2e; color: #e0e0e0; min-height: 100vh; }
        .navbar { background: #16213e !important; border-bottom: 1px solid #0f3460; }
        .navbar-brand { color: #e94560 !important; font-weight: 700; }
        .nav-link { color: #a0a0b0 !important; }
        .nav-link:hover { color: #e94560 !important; }
        .badge-online { background: #28a745; width: 10px; height: 10px;
            border-radius: 50%; display: inline-block; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/chat">
               <i class="bi bi-globe-central-south-asia">|</i>Blog
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    {{#if isLoggedIn}}
                    <li class="nav-item">
                        <span class="nav-link">
                            <span class="badge-online me-1"></span>
                            {{ currentUser.name }}
                        </span>
                    </li>
                    <li class="nav-item">
                        <form action="/logout" method="GET">
                            <button class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </button>
                        </form>
                    </li>
                    {{else}}
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">Register</a>
                    </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>
    <div class="container-fluid px-0">
        {{{body}}}
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
